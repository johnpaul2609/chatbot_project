import sqlite3
import json
from datetime import datetime

def create_database():
    """Creates SQLite database with all tables and sample data"""
    
    conn = sqlite3.connect('college_chatbot.db')
    cursor = conn.cursor()
    
    # ════════════════════════════════════════════════════════════
    # TABLE 1: COLLEGES
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS colleges (
        college_id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT NOT NULL,
        address TEXT,
        phone TEXT,
        email TEXT,
        website TEXT,
        established_year INTEGER,
        affiliation TEXT,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
    ''')
    
    # Insert college data
    cursor.execute('''
    INSERT INTO colleges (name, address, phone, email, website, established_year, affiliation)
    VALUES (?, ?, ?, ?, ?, ?, ?)
    ''', (
        'St. Lourdes Engineering College',
        'Kalladipatta Road, Opp KSRTC Bus Stand, Kizhakkumpattukara, Thrissur, Kerala 680013',
        '+91-487-2332299',
        'info@stlourdescollegethrissur.edu.in',
        'www.stlourdescollegethrissur.edu.in',
        2007,
        'APJ Abdul Kalam Technological University (KTU)'
    ))
    
    # ════════════════════════════════════════════════════════════
    # TABLE 2: PROGRAMS
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS programs (
        program_id INTEGER PRIMARY KEY AUTOINCREMENT,
        college_id INTEGER,
        name TEXT NOT NULL,
        department TEXT,
        duration TEXT,
        intake INTEGER,
        fee_per_year INTEGER,
        description TEXT,
        FOREIGN KEY (college_id) REFERENCES colleges(college_id)
    )
    ''')
    
    # Insert programs
    programs_data = [
        (1, 'B.Tech Computer Science and Engineering', 'CSE', '4 years', 60, 85000, 
         'Focus on AI, ML, Web Development, Data Structures, Algorithms, Database Management'),
        (1, 'B.Tech Electronics and Communication Engineering', 'ECE', '4 years', 60, 80000,
         'Focus on Embedded Systems, VLSI, Signal Processing, Communication Networks'),
        (1, 'B.Tech Mechanical Engineering', 'Mechanical', '4 years', 60, 75000,
         'Focus on Thermodynamics, CAD/CAM, Manufacturing, Robotics, Automotive Engineering'),
        (1, 'B.Tech Civil Engineering', 'Civil', '4 years', 60, 75000,
         'Focus on Structural Engineering, Transportation, Environmental Engineering, Surveying')
    ]
    
    cursor.executemany('''
    INSERT INTO programs (college_id, name, department, duration, intake, fee_per_year, description)
    VALUES (?, ?, ?, ?, ?, ?, ?)
    ''', programs_data)
    
    # ════════════════════════════════════════════════════════════
    # TABLE 3: FACILITIES
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS facilities (
        facility_id INTEGER PRIMARY KEY AUTOINCREMENT,
        college_id INTEGER,
        facility_type TEXT NOT NULL,
        name TEXT,
        description TEXT,
        capacity TEXT,
        FOREIGN KEY (college_id) REFERENCES colleges(college_id)
    )
    ''')
    
    facilities_data = [
        (1, 'Hostel', 'Boys Hostel', 'Separate boys hostel with mess, 24/7 security, WiFi', '200 students'),
        (1, 'Hostel', 'Girls Hostel', 'Separate girls hostel with mess, 24/7 security, WiFi', '150 students'),
        (1, 'Library', 'Central Library', 'Digital library with 15,000+ books, e-journals, online resources', '150 seats'),
        (1, 'Lab', 'Computer Lab', '5 computer labs with 300+ systems, latest software, high-speed internet', '60 systems each'),
        (1, 'Sports', 'Sports Complex', 'Indoor and outdoor sports: cricket, football, basketball, badminton, gym', 'All students')
    ]
    
    cursor.executemany('''
    INSERT INTO facilities (college_id, facility_type, name, description, capacity)
    VALUES (?, ?, ?, ?, ?)
    ''', facilities_data)
    
    # ════════════════════════════════════════════════════════════
    # TABLE 4: PLACEMENTS
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS placements (
        placement_id INTEGER PRIMARY KEY AUTOINCREMENT,
        college_id INTEGER,
        year INTEGER,
        total_students INTEGER,
        students_placed INTEGER,
        placement_percentage REAL,
        highest_package REAL,
        average_package REAL,
        top_recruiters TEXT,
        FOREIGN KEY (college_id) REFERENCES colleges(college_id)
    )
    ''')
    
    cursor.execute('''
    INSERT INTO placements (college_id, year, total_students, students_placed, placement_percentage, 
                           highest_package, average_package, top_recruiters)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    ''', (
        1, 2024, 240, 204, 85.0, 12.5, 4.5,
        'TCS, Infosys, Wipro, Cognizant, Tech Mahindra, Accenture, IBM, Amazon'
    ))
    
    # ════════════════════════════════════════════════════════════
    # TABLE 5: INTENTS
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS intents (
        intent_id INTEGER PRIMARY KEY AUTOINCREMENT,
        intent_tag TEXT UNIQUE NOT NULL,
        category TEXT,
        description TEXT,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
    ''')
    
    intents_data = [
        ('greeting', 'General', 'Greetings and initial conversation starters'),
        ('goodbye', 'General', 'Farewells and conversation endings'),
        ('thanks', 'General', 'Expressions of gratitude'),
        ('admission_process', 'Admission', 'Information about admission procedures'),
        ('fees', 'Admission', 'Information about fee structure'),
        ('eligibility', 'Admission', 'Eligibility criteria for admission'),
        ('programs', 'Academic', 'Information about available programs'),
        ('cse_details', 'Academic', 'Computer Science Engineering details'),
        ('placements', 'Academic', 'Placement statistics and companies'),
        ('facilities', 'Facilities', 'College facilities information'),
        ('hostel', 'Facilities', 'Hostel accommodation details'),
        ('contact', 'General', 'Contact information'),
        ('notes', 'Academic', 'Study materials and notes'),
        ('faculty', 'Academic', 'Faculty information'),
        ('unknown', 'General', 'Fallback for unrecognized queries')
    ]
    
    cursor.executemany('''
    INSERT INTO intents (intent_tag, category, description)
    VALUES (?, ?, ?)
    ''', intents_data)
    
    # ════════════════════════════════════════════════════════════
    # TABLE 6: INTENT_PATTERNS (Training Data)
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS intent_patterns (
        pattern_id INTEGER PRIMARY KEY AUTOINCREMENT,
        intent_id INTEGER,
        pattern TEXT NOT NULL,
        FOREIGN KEY (intent_id) REFERENCES intents(intent_id)
    )
    ''')
    
    # Get intent IDs
    cursor.execute("SELECT intent_id, intent_tag FROM intents")
    intent_map = {tag: id for id, tag in cursor.fetchall()}
    
    # Training patterns for each intent
    training_patterns = {
        'greeting': [
            'hi', 'hello', 'hey', 'good morning', 'good afternoon', 'good evening',
            'hi there', 'hello there', 'hey there', 'greetings', 'whats up',
            'how are you', 'is anyone there', 'start', 'help'
        ],
        'goodbye': [
            'bye', 'goodbye', 'see you', 'see you later', 'talk to you later',
            'bye bye', 'catch you later', 'thanks bye', 'ok bye', 'thank you bye'
        ],
        'thanks': [
            'thanks', 'thank you', 'thank you so much', 'thanks a lot',
            'appreciate it', 'helpful', 'that helps', 'perfect thanks', 'great thanks'
        ],
        'admission_process': [
            'admission process', 'how to apply', 'application process', 'admission procedure',
            'how do i apply', 'how can i get admission', 'admission steps', 'apply for admission',
            'admission form', 'how to join', 'enrollment process', 'admission details'
        ],
        'fees': [
            'fees', 'fee structure', 'tuition fees', 'how much is the fee',
            'cost', 'fee details', 'college fees', 'course fees', 'total fees',
            'fee payment', 'fees for cse', 'fees for ece', 'fees for mechanical'
        ],
        'eligibility': [
            'eligibility', 'eligibility criteria', 'who can apply', 'qualification required',
            'what marks needed', 'minimum marks', 'requirements', 'eligibility requirements',
            'am i eligible', 'can i apply', '10+2 marks', 'entrance exam'
        ],
        'programs': [
            'programs', 'courses', 'departments', 'branches', 'what courses',
            'available programs', 'what can i study', 'course list', 'branches offered',
            'engineering branches', 'btech programs', 'streams available'
        ],
        'cse_details': [
            'cse', 'computer science', 'cs', 'cse details', 'computer engineering',
            'cse department', 'cse course', 'computer science engineering', 'cse subjects',
            'what is taught in cse', 'cse syllabus', 'cse intake'
        ],
        'placements': [
            'placements', 'placement record', 'companies', 'recruiters', 'job opportunities',
            'placement statistics', 'placement percentage', 'average package', 'highest package',
            'which companies come', 'top recruiters', 'placement cell'
        ],
        'facilities': [
            'facilities', 'college facilities', 'infrastructure', 'labs', 'library',
            'sports', 'what facilities', 'amenities', 'campus facilities', 'college infrastructure'
        ],
        'hostel': [
            'hostel', 'accommodation', 'hostel facilities', 'hostel fees', 'boys hostel',
            'girls hostel', 'hostel rooms', 'mess', 'hostel availability', 'residential facility'
        ],
        'contact': [
            'contact', 'phone number', 'email', 'address', 'location', 'how to reach',
            'college address', 'contact details', 'phone', 'email address', 'college location'
        ],
        'notes': [
            'notes', 'study material', 'study notes', 'download notes', 'pdf notes',
            'study resources', 'lecture notes', 'course material', 'syllabus', 'books'
        ],
        'faculty': [
            'faculty', 'teachers', 'professors', 'teaching staff', 'faculty details',
            'who teaches', 'faculty members', 'hod', 'department head'
        ],
        'unknown': [
            'something else', 'other', 'different', 'i dont know'
        ]
    }
    
    # Insert patterns
    for intent_tag, patterns in training_patterns.items():
        intent_id = intent_map[intent_tag]
        for pattern in patterns:
            cursor.execute('''
            INSERT INTO intent_patterns (intent_id, pattern)
            VALUES (?, ?)
            ''', (intent_id, pattern))
    
    # ════════════════════════════════════════════════════════════
    # TABLE 7: INTENT_RESPONSES
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS intent_responses (
        response_id INTEGER PRIMARY KEY AUTOINCREMENT,
        intent_id INTEGER,
        response_text TEXT NOT NULL,
        FOREIGN KEY (intent_id) REFERENCES intents(intent_id)
    )
    ''')
    
    # Responses for each intent
    responses_data = {
        'greeting': [
            "Hello! Welcome to St. Lourdes Engineering College chatbot. How can I help you today? 🎓",
            "Hi there! I'm here to assist you with admissions, courses, and college information. What would you like to know?",
            "Hey! Welcome! I can help you with admission process, fees, programs, and more. What's your question?"
        ],
        'goodbye': [
            "Goodbye! Feel free to come back if you have more questions. Have a great day! 👋",
            "Thank you for chatting! If you need any more information, I'm here to help. Take care!",
            "Bye! Don't hesitate to reach out if you need anything else. All the best! 😊"
        ],
        'thanks': [
            "You're welcome! Happy to help! Is there anything else you'd like to know?",
            "Glad I could assist! Feel free to ask if you have more questions. 😊",
            "My pleasure! Let me know if you need any other information."
        ],
        'admission_process': [
            "**Admission Process for 2026:**\n\n1️⃣ Fill the online application form on our website\n2️⃣ Submit required documents (10th, 12th mark sheets, ID proof)\n3️⃣ Qualify in KEAM (Kerala Engineering Architecture Medical) entrance exam\n4️⃣ Attend counseling based on your rank\n5️⃣ Pay the admission fee and complete enrollment\n\n📅 Applications open: April 2026\n\nWould you like to know about eligibility or fees?"
        ],
        'fees': [
            "**Fee Structure (Per Year):**\n\n💰 CSE: ₹85,000\n💰 ECE: ₹80,000\n💰 Mechanical: ₹75,000\n💰 Civil: ₹75,000\n\n✅ Includes: Tuition + Lab + Library\n❌ Excludes: Hostel (₹60,000/year extra)\n\n💳 Payment in 2 installments available\n🏆 Scholarships available for top performers\n\nNeed more details about any specific program?"
        ],
        'eligibility': [
            "**Eligibility Criteria:**\n\n📚 Educational Qualification:\n• Passed 10+2 (or equivalent) with Physics, Chemistry, and Mathematics\n• Minimum 60% aggregate marks in PCM\n• No age limit\n\n📝 Entrance Exam:\n• Must appear for KEAM (Kerala Engineering Entrance Exam)\n• Valid KEAM rank required for admission\n\n🌟 Reservation: As per Govt. of Kerala norms\n\nWant to know about the admission process?"
        ],
        'programs': [
            "**Available B.Tech Programs (4 years):**\n\n💻 **Computer Science Engineering (CSE)** - 60 seats\n   Focus: AI, ML, Web Dev, Data Structures\n\n📡 **Electronics & Communication (ECE)** - 60 seats\n   Focus: Embedded Systems, VLSI, Networks\n\n⚙️ **Mechanical Engineering** - 60 seats\n   Focus: Robotics, CAD/CAM, Manufacturing\n\n🏗️ **Civil Engineering** - 60 seats\n   Focus: Structural, Transportation, Surveying\n\nAll programs are AICTE approved and affiliated to KTU.\n\nWould you like details about any specific department?"
        ],
        'cse_details': [
            "**Computer Science Engineering (CSE):**\n\n📌 Duration: 4 years (8 semesters)\n📌 Intake: 60 students per year\n📌 Fee: ₹85,000/year\n\n**What You'll Learn:**\n• Programming (C, C++, Java, Python)\n• Data Structures & Algorithms\n• Database Management Systems\n• Web Development & Mobile Apps\n• Artificial Intelligence & Machine Learning\n• Computer Networks & Cybersecurity\n• Cloud Computing & IoT\n\n**Labs:** 5 dedicated computer labs with 300+ systems\n\n**Placements:** Top companies: TCS, Infosys, Wipro, Amazon, IBM\n\nInterested in CSE admission or want to know about other programs?"
        ],
        'placements': [
            "**Placement Record 2024:**\n\n📊 Placement Rate: 85% (204 out of 240 students)\n💰 Highest Package: ₹12.5 LPA\n💰 Average Package: ₹4.5 LPA\n\n**Top Recruiters:**\n• TCS\n• Infosys\n• Wipro\n• Cognizant\n• Tech Mahindra\n• Accenture\n• IBM\n• Amazon\n\n**Training Provided:**\n✅ Aptitude & Reasoning\n✅ Technical Interview Prep\n✅ Soft Skills & Communication\n✅ Mock Interviews\n\nOur dedicated placement cell ensures maximum opportunities!\n\nWant to know about a specific department's placements?"
        ],
        'facilities': [
            "**College Facilities:**\n\n📚 **Library:** 15,000+ books, e-journals, digital resources, 150 seats\n\n💻 **Labs:** 5 computer labs (300+ systems), electronics lab, mechanical workshop, civil lab\n\n🏠 **Hostels:**\n• Separate boys & girls hostels\n• Mess facility with nutritious food\n• 24/7 security & WiFi\n\n⚽ **Sports:**\n• Cricket, Football, Basketball courts\n• Indoor badminton, Table tennis\n• Fully equipped gym\n\n🚌 **Transport:** Bus facility from major areas\n\n🏥 **Medical:** First aid room with nurse\n\n☕ **Canteen:** Hygienic food at affordable rates\n\nWhich facility would you like more details about?"
        ],
        'hostel': [
            "**Hostel Facilities:**\n\n🏠 **Boys Hostel:**\n• Capacity: 200 students\n• 2-3 sharing rooms\n• Fee: ₹60,000/year (includes food)\n\n🏠 **Girls Hostel:**\n• Capacity: 150 students\n• 2-3 sharing rooms\n• Fee: ₹60,000/year (includes food)\n\n**Amenities:**\n✅ 24/7 security with CCTV\n✅ WiFi connectivity\n✅ Hot water facility\n✅ Common room with TV\n✅ Mess with nutritious vegetarian & non-veg food\n✅ Laundry facility\n✅ Study room\n\n**Food:**\n• Breakfast, Lunch, Evening snacks, Dinner\n• Hygienic kitchen\n• Menu changes daily\n\nHostel admission is on first-come-first-serve basis!\n\nWant to know more about facilities or fees?"
        ],
        'contact': [
            "**Contact Information:**\n\n📍 **Address:**\nSt. Lourdes Engineering College\nKalladipatta Road, Opp KSRTC Bus Stand\nKizhakkumpattukara\nThrissur, Kerala 680013\n\n📞 **Phone:** +91-487-2332299\n\n📧 **Email:** info@stlourdescollegethrissur.edu.in\n\n🌐 **Website:** www.stlourdescollegethrissur.edu.in\n\n🕐 **Office Hours:**\nMon-Fri: 9:00 AM - 5:00 PM\nSat: 9:00 AM - 1:00 PM\n\n📌 **Location:** Near KSRTC Bus Stand, easily accessible by public transport\n\nFeel free to visit us or call for any queries!"
        ],
        'notes': [
            "**Study Materials & Notes:**\n\n📚 We provide PDF notes for all subjects!\n\n**Available for:**\n• Computer Science (CSE)\n• Electronics & Communication (ECE)\n• Mechanical Engineering\n• Civil Engineering\n\n**Subjects Covered:**\n• Semester-wise notes (1st to 8th sem)\n• Previous year question papers\n• Lab manuals\n• Project ideas & reports\n\n📥 **How to Access:**\n1. Visit our website\n2. Go to 'Academics' → 'Study Materials'\n3. Select your department & semester\n4. Download PDFs for free\n\n🔗 Direct link: www.stlourdescollegethrissur.edu.in/notes\n\nNeed notes for a specific subject or semester?"
        ],
        'faculty': [
            "**Faculty Details:**\n\n👨‍🏫 **Teaching Staff:**\n• Total Faculty: 80+\n• PhD Holders: 25+\n• Industry Experience: 40+\n• All faculty members are approved by KTU and AICTE\n\n**Department-wise HODs:**\n• CSE: Dr. Rajesh Kumar (PhD, IIT Delhi)\n• ECE: Dr. Priya Menon (PhD, NIT Calicut)\n• Mechanical: Dr. Suresh Nair (PhD, CUSAT)\n• Civil: Dr. Maya Thomas (PhD, Anna University)\n\n**Qualifications:**\n✅ M.Tech / ME from premier institutions\n✅ Regular FDP (Faculty Development Programs)\n✅ Research publications in international journals\n✅ Industry-academia collaborations\n\nOur faculty ensures quality education with practical industry exposure!\n\nWant to know about placements or facilities?"
        ],
        'unknown': [
            "I'm sorry, I didn't quite understand that. I can help you with:\n\n🎓 Admission process & eligibility\n💰 Fee structure\n📚 Programs & departments (CSE, ECE, Mech, Civil)\n🏆 Placements & companies\n🏠 Hostel & facilities\n📞 Contact information\n📄 Study notes download\n\nCould you please rephrase your question or choose from the above topics?"
        ]
    }
    
    # Insert responses
    for intent_tag, responses in responses_data.items():
        intent_id = intent_map[intent_tag]
        for response in responses:
            cursor.execute('''
            INSERT INTO intent_responses (intent_id, response_text)
            VALUES (?, ?)
            ''', (intent_id, response))
    
    # ════════════════════════════════════════════════════════════
    # TABLE 8: CONVERSATIONS (Chat History)
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS conversations (
        conversation_id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id TEXT,
        user_message TEXT NOT NULL,
        bot_response TEXT NOT NULL,
        intent_detected TEXT,
        confidence_score REAL,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
    ''')
    
    # ════════════════════════════════════════════════════════════
    # TABLE 9: STUDY_MATERIALS
    # ════════════════════════════════════════════════════════════
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS study_materials (
        material_id INTEGER PRIMARY KEY AUTOINCREMENT,
        program_id INTEGER,
        semester INTEGER,
        subject_name TEXT,
        material_type TEXT,
        file_url TEXT,
        uploaded_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (program_id) REFERENCES programs(program_id)
    )
    ''')
    
    # Sample study materials
    materials_data = [
        (1, 1, 'Data Structures', 'Notes', 'https://example.com/cse/sem3/ds_notes.pdf'),
        (1, 1, 'Data Structures', 'Previous Papers', 'https://example.com/cse/sem3/ds_papers.pdf'),
        (1, 2, 'Database Management', 'Notes', 'https://example.com/cse/sem4/dbms_notes.pdf'),
        (1, 3, 'Machine Learning', 'Notes', 'https://example.com/cse/sem6/ml_notes.pdf'),
    ]
    
    cursor.executemany('''
    INSERT INTO study_materials (program_id, semester, subject_name, material_type, file_url)
    VALUES (?, ?, ?, ?, ?)
    ''', materials_data)
    
    # ════════════════════════════════════════════════════════════
    # COMMIT AND CLOSE
    # ════════════════════════════════════════════════════════════
    conn.commit()
    conn.close()
    
    print("✅ Database created successfully!")
    print("✅ 9 tables created")
    print("✅ Sample data inserted")
    print("✅ 15 intents with training patterns")
    print("✅ Ready to train the ML model!")

if __name__ == "__main__":
    create_database()